# ============================================================
# InterviewPilot 环境变量模板
# 复制为 .env 后填写真实值，切勿将含真实密钥的 .env 提交到 Git。
# 生产 Docker Compose 从 AI-Meeting 目录启动时，优先使用 AI-Meeting/.env.example。
# ============================================================

# --------------------------------------------------
# 数据库配置
# --------------------------------------------------
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=mainshi_agent
MONGODB_DATABASE=interview_pilot
REDIS_PASSWORD=

# --------------------------------------------------
# Mimo Token Plan（项目默认，覆盖聊天、面试、ASR、TTS）
# --------------------------------------------------
MIMO_API_KEY=tp-your-token-plan-api-key
MIMO_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_CHAT_MODEL=mimo-v2.5
MIMO_PRO_MODEL=mimo-v2.5-pro
MIMO_ASR_MODEL=mimo-v2.5-asr
MIMO_TTS_MODEL=mimo-v2.5-tts

# Spring AI 默认也走 Mimo OpenAI 兼容接口
SPRING_AI_OPENAI_API_KEY=tp-your-token-plan-api-key
SPRING_AI_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
SPRING_AI_OPENAI_MODEL=mimo-v2.5
SPRING_AI_OPENAI_EMBEDDING_MODEL=mimo-v2.5

# 讯飞 legacy 集成默认关闭；只有显式启用旧链路时才需要填写以下变量
LEGACY_XUNFEI_ENABLED=false
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
XUNFEI_RTA_API_KEY=

# --------------------------------------------------
# 可选：镜像与版本覆盖
# --------------------------------------------------
# MYSQL_IMAGE=mysql:8.4
# MONGO_IMAGE=mongo:7.0
# REDIS_IMAGE=redis:7.2
# BACKEND_IMAGE=ai-meeting-backend:latest
# FRONTEND_IMAGE=ai-meeting-frontend:latest
# BUILDER_IMAGE=maven:3.9.11-eclipse-temurin-17
# RUNTIME_IMAGE=eclipse-temurin:17-jre-jammy
