# ============================================================
# InterviewPilot 生产环境环境变量模板
# 复制为 .env 后填写真实值，切勿将含真实密钥的 .env 提交到 Git
# ============================================================

# --------------------------------------------------
# 数据库配置
# --------------------------------------------------
MYSQL_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=mainshi_agent
MONGODB_DATABASE=interview_pilot
REDIS_PASSWORD=

# --------------------------------------------------
# AI 模型密钥（核心功能依赖，必须配置）
# --------------------------------------------------

# OpenAI 兼容接口（如 OpenAI / DeepSeek / Mimo 等）
# 如果使用 Mimo（默认），base_url 通常为 https://token-plan-sgp.xiaomimimo.com/v1
SPRING_AI_OPENAI_API_KEY=sk-your-openai-api-key-here
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_MODEL=gpt-4o-mini

# 讯飞开放平台（ASR 语音识别、TTS 语音合成、工作流智能体）
# 申请地址：https://www.xfyun.cn/
XUNFEI_APP_ID=your_xunfei_app_id
XUNFEI_API_KEY=your_xunfei_api_key
XUNFEI_API_SECRET=your_xunfei_api_secret
XUNFEI_RTA_API_KEY=

# --------------------------------------------------
# 可选：镜像与版本覆盖
# --------------------------------------------------
# MYSQL_IMAGE=mysql:8.4
# MONGO_IMAGE=mongo:7.0
# REDIS_IMAGE=redis:7.2
# BACKEND_IMAGE=ai-meeting-backend:latest
# FRONTEND_IMAGE=ai-meeting-frontend:latest
# BUILDER_IMAGE=maven:3.9.11-eclipse-temurin-17
# RUNTIME_IMAGE=eclipse-temurin:17-jre-jammy
